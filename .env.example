# Kokoro language code: a=en-us, b=en-gb, e=es, f=fr, h=hi, i=it, j=ja, p=pt-br, z=zh
KOKORO_LANG=a

# Default voice if request doesn't specify (or maps to a Kokoro voice id directly)
KOKORO_VOICE=af_heart

# Explicit device override: cpu, cuda, or empty for Kokoro auto-detect
KOKORO_DEVICE=cpu

# Optional bearer token. If set, clients must send: Authorization: Bearer ***
API_KEY=
